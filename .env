# Flask Configuration
SECRET_KEY=your-super-secret-key-change-in-production
FLASK_ENV=development
DEBUG=True

# Vercel KV Configuration (Auto-injected in production)
KV_REST_API_URL=http://localhost:6379
KV_REST_API_TOKEN=

# Redis Configuration (For local development)
REDIS_URL=redis://localhost:6379/0

# Application Settings
APP_NAME=Polytechnic Ibadan Interaction System
INSTITUTION_NAME=The Polytechnic, Ibadan

# Security
PASSWORD_HASH_SALT=your-hash-salt

# File Upload
MAX_CONTENT_LENGTH=16777216
UPLOAD_FOLDER=uploads

# Email Configuration (Optional)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-email-password